NETWORK_CHIEF_DB=data/network.db
MAILBOX_OWNER=you@example.com

# Optional. Keep cloud keys out of git.
OPENAI_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434

# --- OAuth (read-only contact sync) ----------------------------------------
# Register a developer app per provider. The redirect URIs below MUST be
# whitelisted exactly as written (loopback IP, not "localhost").
#   Google:   http://127.0.0.1:47318/callback
#   X.com:    http://127.0.0.1:47319/callback
#   LinkedIn: http://127.0.0.1:47320/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Override the loopback ports if 47318-47320 are busy on this machine.
NETWORK_CHIEF_OAUTH_PORT_GOOGLE=47318
NETWORK_CHIEF_OAUTH_PORT_X=47319
NETWORK_CHIEF_OAUTH_PORT_LINKEDIN=47320

# Set to 1 only if your LinkedIn app has been granted Member Data Portability.
LINKEDIN_DMA_ENABLED=
